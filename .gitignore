# ─── Byte-compiled / optimized / DLL files ────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so

# ─── Numba cache (AOT / JIT artifacts) ────────────────────────────────────
# Numba stores compiled objects as .nbi / .nbc inside __pycache__/, but also
# emits these when NUMBA_CACHE_DIR is set or when AOT is used.
*.nbi
*.nbc
.numba_cache/

