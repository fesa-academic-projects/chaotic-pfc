#: chaotic_pfc.cli.sweep:3 of
msgid "Nested under ``chaotic-pfc run sweep ...`` with four sub-subcommands:"
msgstr ""

#: chaotic_pfc.cli.sweep:5 of
msgid ""
"``compute`` — run the actual numerical sweep for one or more ``(window, "
"filter)`` combinations and save ``.npz`` checkpoints. Originally "
"``scripts/07_henon_sweep_compute.py``."
msgstr ""

#: chaotic_pfc.cli.sweep:8 of
msgid ""
"``plot`` — turn previously saved ``.npz`` checkpoints into the four "
"standard classification figures. Originally "
"``scripts/08_henon_sweep_plot.py``."
msgstr ""

#: chaotic_pfc.cli.sweep:11 of
msgid "``beta-sweep`` — run Kaiser β-sweeps across multiple β values."
msgstr ""

#: chaotic_pfc.cli.sweep:12 of
msgid "``plot-3d`` — render an interactive 3-D surface stack of Kaiser β-sweeps."
msgstr ""

#: chaotic_pfc.cli.sweep:14 of
msgid ""
"The two steps are kept separate so plotting iterations (label sizes, "
"colour maps, format changes) do not require rerunning the multi-hour "
"sweep."
msgstr ""

