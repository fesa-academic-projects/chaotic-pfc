#: chaotic_pfc.dynamics.maps:3 of
msgid ""
"Hénon map variants used as chaotic oscillators throughout the "
"communication system."
msgstr ""

#: chaotic_pfc.dynamics.maps:6 of
msgid "Four Henon map variants and one chaotic-sequence generator are provided:"
msgstr ""

#: chaotic_pfc.dynamics.maps:8 of
msgid ":func:`henon_standard` — the original Hénon (1976) map,"
msgstr ""

#: chaotic_pfc.dynamics.maps:10 of
msgid ""
"x[n+1] &= 1 - a \\, x[n]^2 + y[n] \\\\\n"
"y[n+1] &= b \\, x[n]"
msgstr ""

#: chaotic_pfc.dynamics.maps:15 of
msgid "chaotic at ``(a, b) = (1.4, 0.3)``."
msgstr ""

#: chaotic_pfc.dynamics.maps:17 of
msgid ""
":func:`henon_generalised` — the parametric form preferred in "
"communications literature,"
msgstr ""

#: chaotic_pfc.dynamics.maps:20 of
msgid ""
"x_1[n+1] &= \\alpha - x_1[n]^2 + \\beta \\, x_2[n] \\\\\n"
"x_2[n+1] &= x_1[n]"
msgstr ""

#: chaotic_pfc.dynamics.maps:25 of
msgid "equivalent to :func:`henon_standard` with rescaled variables."
msgstr ""

#: chaotic_pfc.dynamics.maps:27 of
msgid ""
":func:`henon_filtered` — generalised Hénon whose nonlinear input is a "
"weighted combination of two consecutive state samples:"
msgstr ""

#: chaotic_pfc.dynamics.maps:30 of
msgid ""
"x_1[n+1] &= \\alpha - (c_0 \\, x_1[n] + c_1 \\, x_2[n])^2 + \\beta \\, "
"x_2[n] \\\\\n"
"x_2[n+1] &= x_1[n]"
msgstr ""

#: chaotic_pfc.dynamics.maps:35 of
msgid "This is the 2-tap case of the general filtered map."
msgstr ""

#: chaotic_pfc.dynamics.maps:37 of
msgid ""
":func:`henon_order_n` — general case with an FIR filter of arbitrary "
"order acting on the system's state vector. Used by the higher-order "
"transmitter/receiver pair and by the Lyapunov sweep."
msgstr ""

#: chaotic_pfc.dynamics.maps:41 of
msgid ""
":func:`henon_fir_sequence` — generates a chaotic sequence from the FIR-"
"filtered Hénon map, used by the DCSK communication schemes."
msgstr ""

