"\\(r\\, fir\\_coeffs\\[\\, mu\\, a\\, b\\, ...\\]\\)"
msgstr ""

#: ../../api/generated/chaotic_pfc.comms.receiver.rst:12:<autosummary>:1
#: chaotic_pfc.comms.receiver.receive_order_n:1 of
msgid "Demodulate the carrier ``r`` via N-th order Hénon synchronisation."
msgstr ""

#: chaotic_pfc.comms.receiver.receive:3 of
msgid "The local oscillator is driven by ``r`` itself:"
msgstr ""

#: chaotic_pfc.comms.receiver.receive:5 of
msgid ""
"y_1[n+1] &= a - r[n]^2 + b \\, y_2[n] \\\\\n"
"y_2[n+1] &= y_1[n]"
msgstr ""

#: chaotic_pfc.comms.receiver.receive:10 of
msgid ""
"This is the Pecora-Carroll trick: once ``y`` locks onto the transmitter's"
" state, ``r[n] - y_1[n]`` equals the instantaneous modulation and "
"dividing by ``μ`` recovers the message."
msgstr ""

